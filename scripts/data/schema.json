{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Substances and Paraphernalia — module schema",
  "schemaVersion": 2,
  "moduleId": "substances-and-paraphernalia",
  "flagScope": "substances-and-paraphernalia",
  "kinds": [
    { "id": "substance", "labelKey": "FISHUT.Kind.Substance" },
    { "id": "paraphernalia", "labelKey": "FISHUT.Kind.Paraphernalia" }
  ],
  "categories": [
    { "id": "stimulant", "labelKey": "FISHUT.Category.Stimulant" },
    { "id": "mindAltering", "labelKey": "FISHUT.Category.MindAltering" },
    { "id": "performanceEnhancing", "labelKey": "FISHUT.Category.PerformanceEnhancing" }
  ],
  "settings": [
    { "id": "fantasy", "labelKey": "FISHUT.Setting.Fantasy" },
    { "id": "sciFi", "labelKey": "FISHUT.Setting.SciFi" },
    { "id": "modern", "labelKey": "FISHUT.Setting.Modern" }
  ],
  "administrations": [
    { "id": "inhaled", "labelKey": "FISHUT.Administration.Inhaled" },
    { "id": "ingested", "labelKey": "FISHUT.Administration.Ingested" },
    { "id": "injected", "labelKey": "FISHUT.Administration.Injected" },
    { "id": "sublingual", "labelKey": "FISHUT.Administration.Sublingual" },
    { "id": "topical", "labelKey": "FISHUT.Administration.Topical" }
  ],
  "addictionSaveBypassTypes": [
    { "id": "auto-pass", "labelKey": "FISHUT.SaveBypass.Type.AutoPass" }
  ],
  "worldSettings": [
    {
      "key": "enforceParaphernalia",
      "scope": "world",
      "type": "Boolean",
      "default": true,
      "nameKey": "FISHUT.Settings.EnforceParaphernalia.Name",
      "hintKey": "FISHUT.Settings.EnforceParaphernalia.Hint"
    },
    {
      "key": "strictDaeRequirement",
      "scope": "world",
      "type": "Boolean",
      "default": false,
      "nameKey": "FISHUT.Settings.StrictDaeRequirement.Name",
      "hintKey": "FISHUT.Settings.StrictDaeRequirement.Hint"
    }
  ],
  "clientSettings": [
    {
      "key": "suppressIntegrationWarnings",
      "scope": "client",
      "type": "Boolean",
      "default": false,
      "nameKey": "FISHUT.Settings.SuppressIntegrationWarnings.Name",
      "hintKey": "FISHUT.Settings.SuppressIntegrationWarnings.Hint"
    },
    {
      "key": "debug",
      "scope": "client",
      "type": "Boolean",
      "default": false,
      "nameKey": "FISHUT.Settings.Debug.Name",
      "hintKey": "FISHUT.Settings.Debug.Hint"
    }
  ],
  "flagKeys": {
    "kind": "kind",
    "category": "category",
    "setting": "setting",
    "tags": "tags",
    "paraphernaliaId": "paraphernaliaId",
    "requiredParaphernalia": "requiredParaphernalia",
    "requiresDae": "requiresDae",
    "administration": "administration",
    "addiction": "addiction",
    "addictionSaveBypass": "addictionSaveBypass",
    "sourceSubstanceId": "sourceSubstanceId",
    "withdrawal": "withdrawal",
    "schemaVersion": "schemaVersion"
  }
}
